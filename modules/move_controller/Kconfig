menu "Move controller module"

config MOVE_CONTROLLER_MODULE
	bool "Enable move controller module"
	default y
	depends on QUADRUPED_MODULE

config MOVE_CONTROLLER_MODULE_LOG_LEVEL
	int "Move controller module log level"
	range 0 4
	default 3
	depends on MOVE_CONTROLLER_MODULE && LOG

endmenu
