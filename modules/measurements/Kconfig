menu "Measurements module"

config MEASUREMENTS_MODULE
	bool "Enable measurements module"
	default y
	depends on ADC && SENSOR

config MEASUREMENTS_MODULE_INIT_PRIORITY
	int "Measurements device init priority"
	range 0 999
	default 92
	depends on MEASUREMENTS_MODULE

config MEASUREMENTS_MODULE_LOG_LEVEL
	int "Measurements module log level"
	range 0 4
	default 3
	depends on MEASUREMENTS_MODULE && LOG

endmenu
