menuconfig LED_MODULE
	bool "LED module"
	depends on GPIO
	help
	  Enable onboard LED helper API.

if LED_MODULE

config LED_MODULE_LOG_LEVEL
	int "LED module log level"
	range 0 4
	default 3
	depends on LOG
	help
	  Log level for the LED module.
	  0: off, 1: error, 2: warning, 3: info, 4: debug.

endif
